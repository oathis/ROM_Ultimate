__pycache__/
*.py[cod]
.pytest_cache/

# Ignore data but keep directories
data/processed/*
!data/processed/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/splits/*
!data/splits/.gitkeep

# Generated ROM outputs (do not commit large artifacts)
models/
predictions/
artifacts/models/*
!artifacts/models/.gitkeep
artifacts/modes/*
!artifacts/modes/.gitkeep
artifacts/reports/*
!artifacts/reports/.gitkeep
artifacts/scalers/*
!artifacts/scalers/.gitkeep
artifacts/sessions/*
!artifacts/sessions/.gitkeep

# Generated media/debug outputs
*.gif
*.mp4
